{
  "name": "automation-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript/ADK 1:1 clone of the automation-agent Go service: ingests events, routes through a root dispatcher, and runs summary / lint-fixer / coverage-fixer workflows.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx cmd/agent/main.ts",
    "playground": "tsx cmd/playground/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "cover": "vitest run --coverage",
    "arch": "vitest run arch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier --write \"**/*.ts\""
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google/adk": "^1.3.0",
    "@google/genai": "^1.37.0",
    "@octokit/rest": "^21.0.0",
    "croner": "^9.0.0",
    "express": "^4.21.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
