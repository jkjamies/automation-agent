# automation-agent configuration — copy to .env and fill in.
# See .agents/standards/architecture-design.md §12 for the full table.

# --- LLM provider ---------------------------------------------------------
LLM_PROVIDER=ollama            # ollama | gemini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:12b        # default: triage, explore, summary
OLLAMA_CODE_MODEL=gemma4:26b   # larger model for code changes (lint rewrite, test gen). (blank = same as OLLAMA_MODEL)
GEMINI_MODEL=                  # used when LLM_PROVIDER=gemini
GEMINI_CODE_MODEL=             # blank = same as GEMINI_MODEL

# --- Sessions (durable suspend/resume) ------------------------------------
SESSION_BACKEND=memory         # memory (tests/ephemeral) | sqlite (durable local) | firestore (cloud)
SQLITE_DSN=file:automation-agent.db?_pragma=busy_timeout(5000)  # used when SESSION_BACKEND=sqlite
FIRESTORE_PROJECT=             # SESSION_BACKEND=firestore; blank = detect from ADC / GOOGLE_CLOUD_PROJECT
FIRESTORE_COLLECTION=automation_agent  # collection-name prefix for firestore docs

# --- GitHub / repos -------------------------------------------------------
REPOS=                         # comma-separated owner/repo,owner/repo2
GITHUB_TOKEN=                   # blank: falls back to GH_TOKEN, then `gh auth token` (local gh login)

# --- Notifications --------------------------------------------------------
NOTIFY_PROVIDER=slack          # slack | teams
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Server / schedule ----------------------------------------------------
PORT=8080
CRON_DAILY=0 9 * * *           # 09:00 every day
CRON_WEEKLY=0 9 * * 1          # 09:00 every Monday

# --- Lint-fixer -----------------------------------------------------------
MAX_ITERATIONS=3
CI_TIMEOUT=90m                 # max wait for a CI result before a run times out (notify + stop)
GITHUB_WEBHOOK_SECRET=
AGENT_PR_LABEL=automation-agent
AGENT_CHECK_NAME=agent-lint-verify

# --- Cloud Scheduler ingress (/internal/*) --------------------------------
# Bearer token Cloud Scheduler attaches when calling /internal/cron/{daily,weekly}
# and /internal/sweep. Blank disables those endpoints (they return 404).
INTERNAL_TOKEN=
