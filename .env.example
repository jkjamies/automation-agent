# automation-agent configuration — copy to .env and fill in.
# See .agents/standards/architecture-design.md §12 for the full table.
#
# Style: every comment is on its own line, never trailing a value. A trailing
# comment after a BLANK value (KEY=  # note) is parsed by godotenv as the value
# itself — the comment string silently becomes the setting. Keep comments above.

# --- LLM provider ---------------------------------------------------------
# ollama | gemini
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
# default model: triage, explore, summary
OLLAMA_MODEL=gemma4:12b
# larger model for code changes (lint rewrite, test gen); blank = same as OLLAMA_MODEL
OLLAMA_CODE_MODEL=gemma4:26b
# used when LLM_PROVIDER=gemini
GEMINI_MODEL=
# blank = same as GEMINI_MODEL
GEMINI_CODE_MODEL=

# --- Sessions (durable suspend/resume) ------------------------------------
# memory (tests/ephemeral) | sqlite (durable local) | firestore (cloud)
SESSION_BACKEND=memory
# used when SESSION_BACKEND=sqlite
SQLITE_DSN=file:automation-agent.db?_pragma=busy_timeout(5000)
# SESSION_BACKEND=firestore; blank = detect from ADC / GOOGLE_CLOUD_PROJECT
FIRESTORE_PROJECT=
# collection-name prefix for firestore docs
FIRESTORE_COLLECTION=automation_agent

# --- GitHub / repos -------------------------------------------------------
# comma-separated owner/repo,owner/repo2.
# NOTE: required (non-empty) in GitHub App mode — an empty list ("all repos") is
# rejected at startup so the App never acts on every repo it is installed on.
REPOS=
# Personal access token — the LOCAL-DEV fallback, used when the GITHUB_APP_* vars
# below are unset. Blank: falls back to GH_TOKEN, then `gh auth token` (local gh login).
GITHUB_TOKEN=
# https (PAT / GitHub App token) | ssh (local dev: ssh-agent/keys).
# NOTE: ssh only authenticates git clone/push, never the GitHub REST API (open/label
# PR, read CI). In PAT mode that means with ssh you must still `gh auth login` (or set
# GITHUB_TOKEN) or PR operations fail. In App mode the REST API uses the App token
# regardless of transport, so ssh + App mode needs no extra PAT.
GIT_TRANSPORT=https
# GIT_TRANSPORT=ssh: explicit private-key path; blank = ssh-agent then ~/.ssh/id_*
GIT_SSH_KEY=

# --- GitHub App auth (production) -----------------------------------------
# Production authenticates as a GitHub App: short-lived (~1h), repo-scoped
# installation tokens minted/refreshed automatically. With no GITHUB_APP_* vars set,
# the GITHUB_TOKEN PAT above is used. Once any GITHUB_APP_* var is present, App mode is
# intended and the full set is required — GITHUB_APP_ID + a private key +
# GITHUB_APP_INSTALLATION_ID. Single org per deployment (one pinned installation). A
# partial/misconfigured App setup is a startup error, not a silent fallback to PAT.
# numeric App ID; its presence (with a key + installation id) selects App mode
GITHUB_APP_ID=
# pinned installation for this deployment's org (required in App mode)
GITHUB_APP_INSTALLATION_ID=
# the App private key — set EXACTLY ONE of the next two (both set is an error):
# local dev: path to the .pem file (sidesteps multiline .env quoting)
GITHUB_APP_PRIVATE_KEY_PATH=
# cloud (Secret Manager): the literal PEM contents; a flattened \n is auto-restored
GITHUB_APP_PRIVATE_KEY=

# --- Notifications --------------------------------------------------------
# slack | teams
NOTIFY_PROVIDER=slack
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Server ---------------------------------------------------------------
PORT=8080

# --- Lint-fixer -----------------------------------------------------------
MAX_ITERATIONS=3
# max wait for a CI result before a run times out (notify + stop)
CI_TIMEOUT=90m
GITHUB_WEBHOOK_SECRET=
# label applied to every agent PR (write-only; lookup is by branch)
AGENT_PR_LABEL=automation-agent

# --- Reviewer (PR code-review agent) --------------------------------------
# Kill switch. false (default): pull_request events are acknowledged but no
# reviewer work runs. true: enable the current kickoff path, which only logs
# receipt today — diff fetch, sub-agents, scoring, and publishing land later.
REVIEW_ENABLED=false
# Skip draft PRs unless the event is ready_for_review (default true).
REVIEW_SKIP_DRAFTS=true
# Paths excluded before sizing/review (generated, vendored, lockfiles,
# minified, binaries). A pattern without "/" matches the basename; one with
# "/" matches the full path ("**" crosses separators). Blank uses the built-in
# default set.
REVIEW_EXCLUDE_GLOBS=
# Size gate (two-dimensional, measured on the filtered diff): a PR over either
# cap is denied, not degraded. A non-positive value (0 or negative) disables a
# dimension. Defaults: 50 / 262144.
REVIEW_MAX_FILES=50
REVIEW_MAX_DIFF_BYTES=262144

# Verify gate: drop findings below this confidence (0..1) before scoring. A
# non-positive value keeps everything. Default: 0.6.
REVIEW_MIN_CONFIDENCE=0.6

# Debounce window for rapid pushes: a synchronize (re-push) review is enqueued
# with this delay under a per-PR dedup name, so a burst collapses to one task on
# the latest SHA (an execution-time staleness check enforces newest-wins). A
# non-positive value disables debounce. Only the Cloud Tasks transport honors it.
# Default: 30s.
REVIEW_DEBOUNCE=30s

# Standards-aware review: discover the REVIEWED repo's own convention docs
# (.agents/standards, .cursor/rules, CLAUDE.md, CONTRIBUTING.md, linter configs, …)
# via the API, distill them with the base model into a tagged rule list, and steer
# the lenses off them. Default: true (set false to review generically).
REVIEW_STANDARDS=true

# Discovery globs matched against the reviewed repo's tree (comma-separated; blank
# uses the built-in defaults). A glob with no '/' matches the basename; one with a
# '/' matches the full path ('**' crosses separators).
REVIEW_STANDARDS_GLOBS=

# Cap on total standards-doc bytes fed to the distiller. Default: 262144 (256 KiB).
REVIEW_STANDARDS_MAX_BYTES=262144

# How to handle a pattern/architecture finding that cites no real repo rule:
# "nitpick" (demote — the gentle default) or "drop" (remove). Findings in other
# dimensions (e.g. security) never need a citation.
REVIEW_UNCITED_MODE=nitpick

# --- Internal ingress (/internal/*) ---------------------------------------
# Bearer token attached when calling /internal/cron/daily and /internal/sweep
# (Cloud Scheduler) and /internal/dispatch (the Cloud Tasks worker). Blank
# disables those endpoints (they return 404).
INTERNAL_TOKEN=

# --- Execution transport (webhook -> dispatcher) --------------------------
# A webhook must return fast, but the workflow it triggers is multi-minute LLM
# compute. On Cloud Run, CPU is throttled once the response is sent, so that
# compute must run INSIDE a request. TASKS_BACKEND selects how:
#   inprocess  - local/default: an in-process background worker pool (not
#                durable; reproduces the pre-transport behavior).
#   cloudtasks - prod: enqueue each envelope as a Cloud Tasks HTTP-target task
#                -> POST /internal/dispatch, which runs the workflow in-request
#                (CPU stays allocated; durable retry; rate-limited by the queue).
# See specs/20260626-workflow-execution-transport.md.
TASKS_BACKEND=inprocess
# cloudtasks only: GCP project owning the queue; blank = GOOGLE_CLOUD_PROJECT.
TASKS_PROJECT=
# cloudtasks only, REQUIRED: queue region (e.g. us-central1).
TASKS_LOCATION=
# cloudtasks only, REQUIRED: Cloud Tasks queue name.
TASKS_QUEUE=
# cloudtasks only, REQUIRED: absolute https URL the queue POSTs to; must end in
# /internal/dispatch (e.g. https://<service>/internal/dispatch).
DISPATCH_URL=
# cloudtasks only: explicit per-task dispatch deadline; range 15s..30m (Cloud
# Tasks HTTP-target max). The unset queue default is only 10m.
TASKS_DISPATCH_DEADLINE=30m
