# automation-agent (Python) configuration — copy to .env and fill in.
# Kept one-to-one with the Go variant's .env.example. See .agents/standards/architecture-design.md §12.
#
# Style: every comment is on its own line, never trailing a value. A trailing
# comment after a BLANK value (KEY=  # note) can be parsed as the value itself —
# the comment string silently becomes the setting. Keep comments above.

# --- LLM provider ---------------------------------------------------------
# ollama | gemini
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
# default: triage, explore, summary
OLLAMA_MODEL=gemma4:12b
# larger model for code changes (lint rewrite, test gen); blank = same as OLLAMA_MODEL
OLLAMA_CODE_MODEL=gemma4:26b
# used when LLM_PROVIDER=gemini
GEMINI_MODEL=
# blank = same as GEMINI_MODEL
GEMINI_CODE_MODEL=

# --- Sessions (durable suspend/resume) ------------------------------------
# memory (tests/ephemeral) | sqlite (durable local) | firestore (cloud)
SESSION_BACKEND=memory
# used when SESSION_BACKEND=sqlite (adk SqliteSessionService = plain path)
SQLITE_DSN=automation-agent.db
# SESSION_BACKEND=firestore; blank = detect from ADC / GOOGLE_CLOUD_PROJECT
FIRESTORE_PROJECT=
# collection-name prefix for firestore docs
FIRESTORE_COLLECTION=automation_agent

# --- GitHub / repos -------------------------------------------------------
# comma-separated owner/repo,owner/repo2
REPOS=
# blank: falls back to GH_TOKEN, then `gh auth token` (local gh login)
GITHUB_TOKEN=
# https (token / GitHub App) | ssh (local dev: ssh-agent/keys).
# NOTE: ssh only authenticates git clone/push. The GitHub REST API (open/label
# PR, read CI) still needs a token — so with ssh you must still `gh auth login`
# (or set GITHUB_TOKEN) or PR operations will fail.
GIT_TRANSPORT=https
# GIT_TRANSPORT=ssh: explicit private-key path; blank = ssh-agent then ~/.ssh/id_*
GIT_SSH_KEY=

# --- Notifications --------------------------------------------------------
# slack | teams
NOTIFY_PROVIDER=slack
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Server ---------------------------------------------------------------
PORT=8080

# --- Lint-fixer -----------------------------------------------------------
MAX_ITERATIONS=3
# max wait for a CI result before a run times out (notify + stop)
CI_TIMEOUT=90m
GITHUB_WEBHOOK_SECRET=
# label applied to every agent PR (write-only; lookup is by branch)
AGENT_PR_LABEL=automation-agent

# --- Cloud Scheduler ingress (/internal/*) --------------------------------
# Bearer token Cloud Scheduler attaches when calling /internal/cron/daily
# and /internal/sweep. Blank disables those endpoints (they return 404).
INTERNAL_TOKEN=

# --- Observability (OpenTelemetry tracing) --------------------------------
# All off by default: with OTEL_TRACES_EXPORTER=none nothing is registered and
# the service is unchanged. The agent framework already emits a native span tree
# (invoke_agent -> call_llm -> execute_tool, under the GenAI semantic
# conventions); setting an exporter turns it on. The app names no vendor — an
# OTLP backend is an endpoint + headers, not code. See
# .agents/standards/observability.md.
#   none    - no-op (default)
#   console - spans to stdout (local dev; the playground defaults to this)
#   otlp    - any OTLP-native backend or a local Collector (see the two OTLP vars)
#   gcp     - Google Cloud Trace via Application Default Credentials
OTEL_TRACES_EXPORTER=none
# resource service.name on every span
OTEL_SERVICE_NAME=automation-agent
# OTEL_TRACES_EXPORTER=otlp, REQUIRED: the OTLP/HTTP target URL (vendor or
# Collector), e.g. https://otlp.example.com or http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_TRACES_EXPORTER=otlp: comma-separated key=value request headers, e.g. a
# vendor API key (source from Secret Manager in production).
OTEL_EXPORTER_OTLP_HEADERS=
# standard OTel sampler; trace volume is low (one per webhook), so always-on is
# correct — the cost is spans-per-trace, not trace rate.
OTEL_TRACES_SAMPLER=parentbased_always_on
# opt-in capture of prompt/response BODIES as span attributes. Off by default —
# bodies are reviewed source code. Model/token/tool/latency attributes are always
# captured, so "off" still yields rich, cost-aware traces. This is the standard
# GenAI-semconv variable the agent framework reads natively.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false
