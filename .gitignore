# Developer memory — specs live here, never committed (see .agents/templates)
/specs/*
!/specs/.gitkeep

# Local env & secrets
.env
*.local

# Build / test artifacts
/bin/
coverage.out
coverage.gate.out
coverage.html
*.db
*.db-shm
*.db-wal

# Local durable state (only if a future phase adds it)
*.db

# OS / editor noise
.DS_Store
.idea/
.vscode/
.claude/settings.local.json
